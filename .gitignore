# .gitignore — files Git should never track.

# ---------------------------------------------------------------------------
# Secrets and credentials
# ---------------------------------------------------------------------------

# Generic secret file types. Catches stray .env or .key anywhere in the repo.
*.env
*.pem
*.key

secrets/

# Ansible Vault encryption material.
ansible/vault_password.txt
ansible/*.vault

# ---------------------------------------------------------------------------
# Terraform
# ---------------------------------------------------------------------------

# Provider plugins and module cache. Regenerated by terraform init.
.terraform/

# State files include secrets pulled in at apply time. Never commit
# them — state lives in HCP.
*.tfstate
*.tfstate.*

# Local variable files. Hold environment-specific values like project
# IDs. Each team member maintains their own copy.
*.tfvars

# Saved plan files from terraform plan -out=foo.tfplan.
*.tfplan

crash.log
crash.*.log

# Override files take precedence over normal config and rarely belong
# in version control. They exist for local-only adjustments.
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---------------------------------------------------------------------------
# SSH keys
# ---------------------------------------------------------------------------

# Block every file under any .ssh directory. !*.pub re-includes
# public keys, which are not secret.
**/.ssh/*
!**/.ssh/*.pub

# ---------------------------------------------------------------------------
# Editor and IDE files
# ---------------------------------------------------------------------------

.vscode/
.idea/
*.swp
*.swo

# ---------------------------------------------------------------------------
# OS-generated files
# ---------------------------------------------------------------------------

.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Logs and build artifacts
# ---------------------------------------------------------------------------

*.log

# ---------------------------------------------------------------------------
# Internal documentation
# ---------------------------------------------------------------------------

# Contains exposed credentials and notes we do not want public.
project-knowledge-base.md

# ---------------------------------------------------------------------------
# Legacy virtualization
# ---------------------------------------------------------------------------

# Vagrant working directory. Project no longer uses Vagrant — kept
# in case old test runs leave files behind.
.vagrant/

# ---------------------------------------------------------------------------
# Scripting and dependencies
# ---------------------------------------------------------------------------

# Python compiled bytecode and virtual environments.
__pycache__/
*.pyc
.venv/
venv/

# Node.js dependency directory.
node_modules/

# ---------------------------------------------------------------------------
# Ansible
# ---------------------------------------------------------------------------

# Files Ansible writes when a play partially fails, listing failed hosts.
*.retry