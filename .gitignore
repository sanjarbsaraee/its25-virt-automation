# .gitignore — files Git should never track.
# Format: each line is a pattern. Lines with # are comments.
# Patterns starting with ! re-include files matched earlier.

# ---------------------------------------------------------------------------
# Secrets and credentials
# ---------------------------------------------------------------------------

# Generic secret file types. Catches stray .env or .key anywhere in the repo.
*.env
*.pem
*.key

# Whole directories meant for local secret storage.
secrets/

# Ansible Vault encryption material.
ansible/vault_password.txt
ansible/*.vault

# ---------------------------------------------------------------------------
# Terraform
# ---------------------------------------------------------------------------

# Provider plugins and module cache. Regenerated by terraform init.
.terraform/

# State files contain the full inventory of managed resources, including
# secrets pulled in at apply time. Never commit them — state lives in HCP.
*.tfstate
*.tfstate.*

# Local variable files. Holds environment-specific values like project IDs
# and host SSH user. Each team member maintains their own copy.
*.tfvars

# Saved plan files from terraform plan -out=foo.tfplan.
*.tfplan

# Crash logs Terraform writes when something goes wrong.
crash.log
crash.*.log

# Override files take precedence over normal config and rarely belong in
# version control. They exist for local-only adjustments.
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---------------------------------------------------------------------------
# SSH keys
# ---------------------------------------------------------------------------

# Block every file under any .ssh directory in the repo (root, terraform/.ssh,
# nested module dirs). The ! re-include allows public keys (.pub) since
# those are not secret. The ** matches any number of directory levels.
**/.ssh/*
!**/.ssh/*.pub

# ---------------------------------------------------------------------------
# Editor and IDE files
# ---------------------------------------------------------------------------

.vscode/
.idea/
*.swp
*.swo

# ---------------------------------------------------------------------------
# OS-generated files
# ---------------------------------------------------------------------------

.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Logs and build artifacts
# ---------------------------------------------------------------------------

*.log

# ---------------------------------------------------------------------------
# Internal documentation
# ---------------------------------------------------------------------------

# Lives outside git on purpose — contains exposed credentials and notes
# we do not want public.
project-knowledge-base.md

# Ignore all markdown files in the root directory (walkthroughs, notes, etc)
/*.md

# But make sure we still track the main README!
!/README.md

# ---------------------------------------------------------------------------
# Legacy virtualization
# ---------------------------------------------------------------------------

# Vagrant working directory. Project no longer uses Vagrant — kept here
# in case any old test runs leave files behind.
.vagrant/

# ---------------------------------------------------------------------------
# Scripting and dependencies
# ---------------------------------------------------------------------------

# Python compiled bytecode and virtual environments.
__pycache__/
*.pyc
.venv/
venv/

# Node.js dependency directory.
node_modules/

# ---------------------------------------------------------------------------
# Ansible
# ---------------------------------------------------------------------------

# Files Ansible writes when a play partially fails, listing failed hosts.
*.retry