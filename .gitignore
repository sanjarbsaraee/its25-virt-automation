# Prevents secrets, generated files and editor clutter
# from reaching the repository.

# ---------------------------------------------------------------------------
# Secrets and credentials
# ---------------------------------------------------------------------------

*.env
*.pem
*.key
secrets/

ansible/vault_password.txt
ansible/*.vault

# ---------------------------------------------------------------------------
# Terraform
# ---------------------------------------------------------------------------

# Regenerated by terraform init.
.terraform/

# State contains secrets pulled in at apply time.
*.tfstate
*.tfstate.*

# Each team member maintains their own copy.
*.tfvars

*.tfplan
crash.log
crash.*.log

# Override files exist for local-only adjustments.
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---------------------------------------------------------------------------
# SSH keys
# ---------------------------------------------------------------------------

# Block private keys, re-include public keys.
**/.ssh/*
!**/.ssh/*.pub

# ---------------------------------------------------------------------------
# Editor and IDE files
# ---------------------------------------------------------------------------

.vscode/
.idea/
*.swp
*.swo

# ---------------------------------------------------------------------------
# OS-generated files
# ---------------------------------------------------------------------------

.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Logs and build artifacts
# ---------------------------------------------------------------------------

*.log

# ---------------------------------------------------------------------------
# Internal documentation
# ---------------------------------------------------------------------------

# Root markdown files except README.
/*.md
!/README.md

# ---------------------------------------------------------------------------
# Legacy virtualization
# ---------------------------------------------------------------------------

# Project no longer uses Vagrant. Kept in case old test
# runs leave files behind.
.vagrant/

# ---------------------------------------------------------------------------
# Scripting and dependencies
# ---------------------------------------------------------------------------

__pycache__/
*.pyc
.venv/
venv/
node_modules/

# ---------------------------------------------------------------------------
# Ansible
# ---------------------------------------------------------------------------

# Written when a play partially fails.
*.retry